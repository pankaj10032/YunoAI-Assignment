# Production environment configuration for Hugging Face Spaces
APP_NAME=AI Orchestrator
ENVIRONMENT=production
LOG_LEVEL=INFO

# Database configuration
DATABASE_URL=sqlite:///./data/ai_orchestrator.db

# LLM Provider (OpenAI by default, users can set their own API key)
LLM_PROVIDER=openai
OPENAI_MODEL=gpt-4o-mini

# Agent configuration
MAX_AGENT_ITERATIONS=5
DEFAULT_AGENT_TIMEOUT_SECONDS=120

# CORS configuration for Hugging Face Spaces
CORS_ORIGINS=*

# Disable Telegram polling by default (users can enable if they have a token)
ENABLE_TELEGRAM_POLLING=false

# Frontend URL (will be set by Hugging Face Spaces)
FRONTEND_URL=https://huggingface.co/spaces/Pankaj10346/AI-Orchestrator